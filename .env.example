# Copy this to .env (never commit .env)
# Kaggle API credentials — get from https://www.kaggle.com/account
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Python Flask ML service port (default 5001)
ML_PORT=5001

# Rails web app environment
ML_SERVICE_URL=http://localhost:5001
