# Copy this to .env (never commit .env)
#
# Required for the Rails web container (local build or docker-compose.hub.yml):
# use the 32-char hex from price_predictor/config/master.key (same key that
# encrypted config/credentials.yml.enc). Omitted in images — pass at runtime.
# RAILS_MASTER_KEY=
#
# If you have no master key, set a long random hex for production boot (e.g.):
#   openssl rand -hex 64
# SECRET_KEY_BASE=

# Kaggle API credentials — get from https://www.kaggle.com/account
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Python Flask ML service port (default 5001)
ML_PORT=5001

# Rails web app environment
ML_SERVICE_URL=http://localhost:5001
