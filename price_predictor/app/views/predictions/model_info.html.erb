<% content_for :title, "Model Info - PriceTier AI" %>

<div class="mb-8">
  <h1 class="text-3xl font-extrabold text-gray-900 mb-1">Model Performance</h1>
  <p class="text-gray-500">Comparison of all trained classifiers evaluated on the hold-out test set (20% of data).</p>
</div>

<% if flash.now[:error].present? %>
  <!-- ML Service Down -->
  <div class="bg-amber-50 border border-amber-200 rounded-2xl p-8 text-center mb-8">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-amber-100 rounded-2xl mb-4">
      <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.07 16.5c-.77.833.192 2.5 1.732 2.5z"/>
      </svg>
    </div>
    <h2 class="text-xl font-bold text-amber-800 mb-2">ML Service Unavailable</h2>
    <p class="text-amber-700 text-sm mb-6 max-w-md mx-auto"><%= flash.now[:error] %></p>
    <div class="text-left bg-amber-100/60 rounded-xl p-5 max-w-lg mx-auto">
      <p class="text-xs font-bold text-amber-800 mb-2 uppercase tracking-wide">Start the ML service:</p>
      <pre class="text-xs text-amber-700 font-mono whitespace-pre-wrap">cd ml/
pip install -r requirements.txt
bash run_pipeline.sh</pre>
    </div>
  </div>

<% elsif @info %>
  <%
    best     = @info["best_model"] || "N/A"
    metrics  = @info["metrics"] || {}
    thresh   = @info["thresholds"] || {}
    all_mdls = @info["all_models"] || []

    f1_val  = metrics["f1_macro"].to_f
    acc_val = metrics["accuracy"].to_f
    f1w_val = metrics["f1_weighted"].to_f

    f1_colour = f1_val >= 0.75 ? "text-green-600" : f1_val >= 0.60 ? "text-amber-600" : "text-red-500"
  %>

  <!-- -- KPI Cards -- -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

    <div class="bg-gradient-to-br from-indigo-600 to-purple-700 rounded-2xl p-6 text-white">
      <p class="text-white/70 text-xs font-semibold uppercase tracking-wider mb-2">Best Model</p>
      <p class="text-3xl font-black leading-tight"><%= best %></p>
      <p class="text-white/60 text-xs mt-2">Selected by highest macro F1 score</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
      <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider mb-2">F1-Macro Score</p>
      <p class="text-4xl font-black <%= f1_colour %>"><%= (f1_val * 100).round(1) %>%</p>
      <div class="mt-3 h-2 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full rounded-full <%= f1_val >= 0.75 ? 'bg-green-500' : f1_val >= 0.60 ? 'bg-amber-500' : 'bg-red-400' %>"
             style="width:<%= (f1_val * 100).clamp(0,100).round(0) %>%"></div>
      </div>
      <p class="text-xs text-gray-400 mt-2">Target threshold: 60%</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
      <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider mb-2">Accuracy</p>
      <p class="text-4xl font-black text-gray-800"><%= (acc_val * 100).round(1) %>%</p>
      <div class="mt-3 h-2 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-indigo-500" style="width:<%= (acc_val * 100).clamp(0,100).round(0) %>%"></div>
      </div>
      <p class="text-xs text-gray-400 mt-2">Overall classification accuracy</p>
    </div>

  </div>

  <!-- -- All Models Comparison Table -- -->
  <% if all_mdls.any? %>
    <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/60 border border-gray-100 overflow-hidden mb-8">
      <div class="px-8 py-6 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-slate-50">
        <h2 class="text-lg font-bold text-gray-800">All Models Comparison</h2>
        <p class="text-gray-500 text-sm mt-0.5">Sorted by F1-Macro (descending). Bold = best model.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="text-left border-b border-gray-100">
              <th class="px-8 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Rank &amp; Model</th>
              <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Accuracy</th>
              <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">F1-Macro</th>
              <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">F1-Weighted</th>
              <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider w-40">F1 Bar</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% all_mdls.sort_by { |m| -(m["f1_macro"].to_f) }.each_with_index do |m, idx| %>
              <% is_best  = (m["name"] == best)
                 mf1      = m["f1_macro"].to_f
                 macc     = m["accuracy"].to_f
                 mf1w     = m["f1_weighted"].to_f
                 bar_w    = (mf1 * 100).clamp(0,100).round(0)
                 mf1_col  = mf1 >= 0.75 ? "text-green-600" : mf1 >= 0.60 ? "text-amber-600" : "text-red-500"
              %>
              <tr class="<%= is_best ? 'bg-indigo-50/40' : 'hover:bg-gray-50/40' %> transition-colors">
                <td class="px-8 py-4">
                  <div class="flex items-center gap-3">
                    <% if is_best %>
                      <span class="inline-flex items-center justify-center w-6 h-6 bg-indigo-600 text-white text-xs font-bold rounded-full flex-shrink-0">
                        <%= idx + 1 %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center justify-center w-6 h-6 bg-gray-200 text-gray-600 text-xs font-bold rounded-full flex-shrink-0">
                        <%= idx + 1 %>
                      </span>
                    <% end %>
                    <div>
                      <p class="text-sm <%= is_best ? 'font-bold text-indigo-800' : 'font-semibold text-gray-700' %>">
                        <%= m["name"] %>
                      </p>
                      <% if is_best %>
                        <span class="text-xs text-indigo-500 font-medium">Best model - deployed</span>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-4 text-right">
                  <span class="text-sm font-semibold text-gray-700"><%= (macc * 100).round(1) %>%</span>
                </td>
                <td class="px-4 py-4 text-right">
                  <span class="text-sm font-bold <%= mf1_col %>"><%= (mf1 * 100).round(1) %>%</span>
                </td>
                <td class="px-4 py-4 text-right">
                  <span class="text-sm text-gray-500"><%= (mf1w * 100).round(1) %>%</span>
                </td>
                <td class="px-4 py-4 w-40">
                  <div class="h-2.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= is_best ? 'bg-indigo-500' : 'bg-gray-400' %>"
                         style="width:<%= bar_w %>%"></div>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <!-- -- Price Tier Thresholds -- -->
  <% if thresh.any? %>
    <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/60 border border-gray-100 overflow-hidden mb-8">
      <div class="px-8 py-6 border-b border-gray-100">
        <h2 class="text-lg font-bold text-gray-800">Learned Price Tier Thresholds</h2>
        <p class="text-gray-500 text-sm mt-0.5">Percentile-based bins computed from combined training data.</p>
      </div>
      <div class="px-8 py-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <% [
            { key: "p25", label: "25th Percentile", sub: "Budget / Mid-Range boundary" },
            { key: "p50", label: "50th Percentile (Median)", sub: "Mid-Range / Premium boundary" },
            { key: "p75", label: "75th Percentile", sub: "Premium / Luxury boundary" }
          ].each do |pt| %>
            <div class="text-center p-5 bg-gray-50 rounded-2xl border border-gray-100">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-2"><%= pt[:label] %></p>
              <p class="text-3xl font-black text-gray-800"><%= thresh[pt[:key]]&.round(2) %></p>
              <p class="text-xs text-gray-400 mt-2"><%= pt[:sub] %></p>
            </div>
          <% end %>
        </div>

        <!-- Visual gradient bar -->
        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Price Distribution Bands</p>
        <div class="flex rounded-2xl overflow-hidden h-8 mb-1">
          <div class="flex-1 bg-green-400 flex items-center justify-center">
            <span class="text-white text-xs font-bold">Budget</span>
          </div>
          <div class="flex-1 bg-blue-500 flex items-center justify-center">
            <span class="text-white text-xs font-bold">Mid-Range</span>
          </div>
          <div class="flex-1 bg-amber-500 flex items-center justify-center">
            <span class="text-white text-xs font-bold">Premium</span>
          </div>
          <div class="flex-1 bg-purple-600 flex items-center justify-center">
            <span class="text-white text-xs font-bold">Luxury</span>
          </div>
        </div>
        <div class="flex justify-between text-xs text-gray-400 px-1">
          <span>0</span>
          <span><%= thresh["p25"]&.round(0) %></span>
          <span><%= thresh["p50"]&.round(0) %></span>
          <span><%= thresh["p75"]&.round(0) %></span>
          <span>max</span>
        </div>
      </div>
    </div>
  <% end %>

  <!-- -- Architecture Info Panel -- -->
  <div class="bg-gradient-to-br from-slate-800 to-gray-900 rounded-3xl p-8 text-white">
    <h2 class="text-lg font-bold mb-6 text-white">System Architecture</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <div>
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">ML Pipeline (Python)</h3>
        <ul class="space-y-2.5 text-sm text-gray-300">
          <% [
            { colour: "green",  text: "Datasets: Amazon SNAP Mobiles + Flipkart (Kaggle)" },
            { colour: "blue",   text: "Features: TF-IDF bigrams (500 dims) + structured" },
            { colour: "amber",  text: "Models: Logistic Regression, Random Forest, XGBoost, LightGBM" },
            { colour: "purple", text: "Explainability: SHAP TreeExplainer / LinearExplainer" },
            { colour: "pink",   text: "Class balancing: SMOTE oversampling" },
            { colour: "cyan",   text: "Label binning: percentile-based (p25 / p50 / p75)" }
          ].each do |li| %>
            <%
              dot = { "green"=>"bg-green-400","blue"=>"bg-blue-400","amber"=>"bg-amber-400",
                      "purple"=>"bg-purple-400","pink"=>"bg-pink-400","cyan"=>"bg-cyan-400" }[li[:colour]]
            %>
            <li class="flex items-center gap-2.5">
              <span class="w-2 h-2 rounded-full flex-shrink-0 <%= dot %>"></span>
              <%= li[:text] %>
            </li>
          <% end %>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Web App (Ruby on Rails)</h3>
        <ul class="space-y-2.5 text-sm text-gray-300">
          <% [
            { colour: "red",    text: "Rails 7.1.5 - Ruby 3.3.4 - SQLite" },
            { colour: "orange", text: "Tailwind CSS 4 - mobile-responsive UI" },
            { colour: "yellow", text: "HTTParty - communicates with Flask API" },
            { colour: "lime",   text: "Session-based prediction history (10 max)" },
            { colour: "teal",   text: "Flask REST API on port 5001 (ML_SERVICE_URL)" },
            { colour: "sky",    text: "Graceful degradation - works even when ML is down" }
          ].each do |li| %>
            <%
              dot2 = { "red"=>"bg-red-400","orange"=>"bg-orange-400","yellow"=>"bg-yellow-400",
                       "lime"=>"bg-lime-400","teal"=>"bg-teal-400","sky"=>"bg-sky-400" }[li[:colour]]
            %>
            <li class="flex items-center gap-2.5">
              <span class="w-2 h-2 rounded-full flex-shrink-0 <%= dot2 %>"></span>
              <%= li[:text] %>
            </li>
          <% end %>
        </ul>
      </div>

    </div>

    <!-- Metrics legend -->
    <div class="mt-8 pt-6 border-t border-white/10">
      <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Metric Definitions</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-gray-300">
        <div>
          <p class="font-semibold text-white text-xs mb-1">F1-Macro</p>
          <p class="text-xs leading-relaxed">Unweighted mean of per-class F1 scores. Treats all classes equally - important for imbalanced datasets.</p>
        </div>
        <div>
          <p class="font-semibold text-white text-xs mb-1">F1-Weighted</p>
          <p class="text-xs leading-relaxed">Mean F1 weighted by class support (count). Reflects real-world performance when classes have different frequencies.</p>
        </div>
        <div>
          <p class="font-semibold text-white text-xs mb-1">Accuracy</p>
          <p class="text-xs leading-relaxed">Fraction of correctly classified samples. Can be misleading on imbalanced data - hence F1-Macro is preferred.</p>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <div class="bg-gray-50 rounded-2xl p-10 text-center border border-gray-100">
    <p class="text-gray-500">No model information available. Make sure the ML service is running.</p>
    <%= link_to predictions_path, class: "mt-4 inline-block text-indigo-600 font-semibold text-sm hover:underline" do %>
      Go to prediction form
    <% end %>
  </div>
<% end %>
