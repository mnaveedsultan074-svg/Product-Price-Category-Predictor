<% content_for :title, "History — PriceTier AI" %>

<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
  <div>
    <h1 class="text-3xl font-extrabold text-gray-900 mb-1">Prediction History</h1>
    <p class="text-gray-500 text-sm">Your recent predictions this session (up to 10, cleared on browser close).</p>
  </div>
  <%= link_to predictions_path,
        class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700
                text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors shadow-sm self-start" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    New Prediction
  <% end %>
</div>

<% if @predictions.empty? %>
  <!-- Empty state -->
  <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-16 text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-gray-100 rounded-3xl mb-5">
      <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2
             M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
    </div>
    <h2 class="text-xl font-bold text-gray-700 mb-2">No Predictions Yet</h2>
    <p class="text-gray-500 mb-6 max-w-sm mx-auto">
      Your prediction history will appear here once you run your first classification.
    </p>
    <%= link_to "Make Your First Prediction", predictions_path,
          class: "inline-flex items-center gap-2 bg-gradient-to-r from-indigo-600 to-purple-600
                  text-white font-bold px-6 py-3 rounded-xl text-sm shadow-lg shadow-indigo-200
                  hover:shadow-indigo-300 hover:-translate-y-0.5 transition-all" %>
  </div>

<% else %>

  <!-- Summary pills -->
  <div class="mb-5 flex flex-wrap gap-2">
    <% tier_counts = @predictions.group_by { |p| p["prediction"] }.transform_values(&:count) %>
    <% ["budget","mid-range","premium","luxury"].each do |t| %>
      <% next if tier_counts[t].nil? %>
      <%
        bc = { "budget"=>"bg-green-100 text-green-700 border-green-200",
               "mid-range"=>"bg-blue-100 text-blue-700 border-blue-200",
               "premium"=>"bg-amber-100 text-amber-700 border-amber-200",
               "luxury"=>"bg-purple-100 text-purple-700 border-purple-200" }[t]
      %>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border capitalize <%= bc %>">
        <%= t %> &times; <%= tier_counts[t] %>
      </span>
    <% end %>
    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 border border-gray-200">
      Total: <%= @predictions.length %>
    </span>
  </div>

  <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/60 border border-gray-100 overflow-hidden">

    <!-- Desktop table -->
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="text-left border-b border-gray-100 bg-gray-50/50">
            <th class="px-8 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider w-10">#</th>
            <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Product</th>
            <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Tier</th>
            <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Confidence</th>
            <th class="px-4 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Time</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @predictions.each_with_index do |pred, i| %>
            <% t          = pred["prediction"] || "unknown"
               confidence = pred["confidence"].to_f
               bc2 = { "budget"    => "bg-green-100 text-green-700 border border-green-200",
                        "mid-range" => "bg-blue-100 text-blue-700 border border-blue-200",
                        "premium"   => "bg-amber-100 text-amber-700 border border-amber-200",
                        "luxury"    => "bg-purple-100 text-purple-700 border border-purple-200"
                      }.fetch(t, "bg-gray-100 text-gray-700 border border-gray-200")
               bfill = { "budget"=>"bg-green-500","mid-range"=>"bg-blue-500",
                         "premium"=>"bg-amber-500","luxury"=>"bg-purple-500" }.fetch(t,"bg-gray-400")
            %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-8 py-4">
                <span class="text-sm font-bold text-gray-300"><%= i + 1 %></span>
              </td>
              <td class="px-4 py-4 max-w-xs">
                <span class="text-sm font-medium text-gray-800 leading-snug"><%= pred["title"] %></span>
              </td>
              <td class="px-4 py-4">
                <span class="text-xs text-gray-500 capitalize"><%= pred["category"].presence || "—" %></span>
              </td>
              <td class="px-4 py-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold capitalize <%= bc2 %>">
                  <%= t %>
                </span>
              </td>
              <td class="px-4 py-4">
                <% if pred["confidence"].present? %>
                  <div class="flex items-center gap-2">
                    <div class="w-24 h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full rounded-full <%= bfill %>" style="width:<%= [confidence,100].min %>%"></div>
                    </div>
                    <span class="text-xs text-gray-600 font-medium"><%= confidence.round(1) %>%</span>
                  </div>
                <% else %>
                  <span class="text-xs text-gray-400">N/A</span>
                <% end %>
              </td>
              <td class="px-4 py-4">
                <span class="text-xs text-gray-400"><%= pred["timestamp"] %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden divide-y divide-gray-100">
      <% @predictions.each_with_index do |pred, i| %>
        <% t  = pred["prediction"] || "unknown"
           bc3 = { "budget"    => "bg-green-100 text-green-700",
                   "mid-range" => "bg-blue-100 text-blue-700",
                   "premium"   => "bg-amber-100 text-amber-700",
                   "luxury"    => "bg-purple-100 text-purple-700"
                 }.fetch(t, "bg-gray-100 text-gray-700")
        %>
        <div class="px-6 py-4">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-800 mb-0.5 leading-snug"><%= pred["title"] %></p>
              <p class="text-xs text-gray-400"><%= pred["timestamp"] %></p>
            </div>
            <div class="text-right flex-shrink-0">
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold capitalize <%= bc3 %>">
                <%= t %>
              </span>
              <% if pred["confidence"].present? %>
                <p class="text-xs text-gray-400 mt-1"><%= pred["confidence"].to_f.round(1) %>% conf.</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  </div>

  <p class="text-center text-xs text-gray-400 mt-4">
    Session history is stored in an encrypted browser cookie and is not persisted on the server.
  </p>
<% end %>
