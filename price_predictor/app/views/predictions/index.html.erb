<% content_for :title, "Predict — PriceTier AI" %>

<!-- ======================================================
     HERO BANNER
     ====================================================== -->
<div class="mb-10 text-center">
  <div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
    </svg>
    AI-Powered Price Classification
  </div>
  <h1 class="text-4xl font-extrabold text-gray-900 mb-3 leading-tight">
    Product Price&nbsp;Category
    <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">Predictor</span>
  </h1>
  <p class="text-gray-500 text-lg max-w-2xl mx-auto">
    Enter product details and our ensemble ML models will classify it into
    <span class="font-semibold text-green-600">budget</span>,
    <span class="font-semibold text-blue-600">mid-range</span>,
    <span class="font-semibold text-amber-600">premium</span>, or
    <span class="font-semibold text-purple-600">luxury</span>.
  </p>
</div>

<!-- ======================================================
     ML-SERVICE-DOWN BANNER
     ====================================================== -->
<% if flash.now[:error].present? %>
  <div class="mb-6 bg-amber-50 border border-amber-200 rounded-2xl p-6">
    <div class="flex items-start gap-4">
      <div class="bg-amber-100 rounded-xl p-2 flex-shrink-0 mt-0.5">
        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.07 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="font-bold text-amber-800 text-base">ML Service Not Running</h3>
        <p class="text-amber-700 text-sm mt-1"><%= flash.now[:error] %></p>
        <div class="mt-4 bg-white/60 border border-amber-200 rounded-xl p-4">
          <p class="text-xs font-bold text-amber-800 uppercase tracking-wide mb-3">Quick-Start Instructions</p>
          <ol class="text-sm text-amber-700 space-y-2 list-decimal list-inside">
            <li>Open a terminal and <code class="bg-amber-200/70 px-1.5 py-0.5 rounded font-mono text-xs">cd ml/</code></li>
            <li>Install Python deps: <code class="bg-amber-200/70 px-1.5 py-0.5 rounded font-mono text-xs">pip install -r requirements.txt</code></li>
            <li>Run the full pipeline: <code class="bg-amber-200/70 px-1.5 py-0.5 rounded font-mono text-xs">bash run_pipeline.sh</code></li>
            <li>Or step by step:
              <code class="bg-amber-200/70 px-1.5 py-0.5 rounded font-mono text-xs block mt-1">
                python download_data.py &amp;&amp; python preprocess.py &amp;&amp; python train.py &amp;&amp; python predict_service.py
              </code>
            </li>
          </ol>
          <p class="text-xs text-amber-600 mt-3">
            Flask API listens on <strong>http://localhost:5001</strong>.
            Set <code class="font-mono">ML_SERVICE_URL</code> env var to override.
          </p>
        </div>
      </div>
    </div>
  </div>
<% end %>

<!-- ======================================================
     MAIN FORM
     ====================================================== -->
<div class="bg-white rounded-3xl shadow-xl shadow-gray-200/60 border border-gray-100 overflow-hidden">

  <div class="bg-gradient-to-r from-indigo-50 via-purple-50 to-pink-50 border-b border-gray-100 px-8 py-6">
    <div class="flex items-center gap-3">
      <div class="bg-indigo-600 rounded-xl p-2">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-800">Product Information</h2>
        <p class="text-gray-500 text-sm mt-0.5">Only the product title is required.</p>
      </div>
    </div>
  </div>

  <div class="px-8 py-8">
    <%= form_with url: predictions_path, method: :post, local: true, class: "space-y-6" do |f| %>

      <!-- Title -->
      <div>
        <label for="prediction_title" class="block text-sm font-semibold text-gray-700 mb-1.5">
          Product Title <span class="text-red-500">*</span>
        </label>
        <input type="text" id="prediction_title" name="prediction[title]" required
          placeholder="e.g. Samsung Galaxy S24 Ultra 256 GB Titanium Black"
          class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400
                 text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none" />
        <p class="text-xs text-gray-400 mt-1">Include brand, model name and key specs.</p>
      </div>

      <!-- Description -->
      <div>
        <label for="prediction_description" class="block text-sm font-semibold text-gray-700 mb-1.5">
          Product Description
          <span class="text-gray-400 font-normal ml-1">(optional)</span>
        </label>
        <textarea id="prediction_description" name="prediction[description]" rows="4"
          placeholder="e.g. Flagship smartphone with 200 MP camera, S Pen, 5000 mAh battery, AI photo editing..."
          class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400
                 text-sm resize-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none"></textarea>
      </div>

      <!-- Category · Rating · Reviews -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        <div>
          <label for="prediction_category" class="block text-sm font-semibold text-gray-700 mb-1.5">Category</label>
          <select id="prediction_category" name="prediction[category]"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 text-sm bg-white
                   focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none">
            <option value="unknown">-- Select Category --</option>
            <option value="electronics">Electronics</option>
            <option value="mobile phones">Mobile Phones</option>
            <option value="cameras">Cameras &amp; Photography</option>
            <option value="computers">Computers &amp; Laptops</option>
            <option value="home &amp; kitchen">Home &amp; Kitchen</option>
            <option value="clothing">Clothing &amp; Fashion</option>
            <option value="sports">Sports &amp; Fitness</option>
            <option value="books">Books</option>
            <option value="beauty">Beauty &amp; Skincare</option>
            <option value="toys">Toys &amp; Games</option>
            <option value="jewellery">Jewellery</option>
            <option value="watches">Watches</option>
            <option value="automotive">Automotive</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="prediction_rating" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Rating <span class="text-gray-400 font-normal">(0–5)</span>
          </label>
          <input type="number" id="prediction_rating" name="prediction[rating]"
            min="0" max="5" step="0.1" placeholder="e.g. 4.2"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400
                   text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none" />
        </div>

        <div>
          <label for="prediction_review_count" class="block text-sm font-semibold text-gray-700 mb-1.5">
            Review Count
          </label>
          <input type="number" id="prediction_review_count" name="prediction[review_count]"
            min="0" placeholder="e.g. 1500"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400
                   text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none" />
        </div>

      </div>

      <!-- Price (hint) -->
      <div>
        <label for="prediction_price" class="block text-sm font-semibold text-gray-700 mb-1.5">
          Price
          <span class="text-gray-400 font-normal ml-1">(optional — used as input hint only)</span>
        </label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400 text-sm font-medium pointer-events-none">$</span>
          <input type="number" id="prediction_price" name="prediction[price]"
            min="0" step="0.01" placeholder="0.00"
            class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400
                   text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none" />
        </div>
      </div>

      <!-- Submit -->
      <div class="pt-2">
        <button type="submit"
          class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700
                 text-white font-bold py-4 px-8 rounded-2xl text-base transition-all duration-200
                 shadow-lg shadow-indigo-200 hover:shadow-indigo-300 hover:-translate-y-0.5
                 flex items-center justify-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707
                 m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531
                 c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          Predict Price Tier
        </button>
      </div>

    <% end %>
  </div>
</div>

<!-- ======================================================
     TIER EXPLAINER CARDS
     ====================================================== -->
<div class="mt-12">
  <h2 class="text-center text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">What each tier means</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% [
      { colour: "green",  title: "Budget",
        icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
        desc: "Entry-level pricing. Great everyday value for most shoppers." },
      { colour: "blue",   title: "Mid-Range",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
        desc: "Balanced cost and features for mainstream consumers." },
      { colour: "amber",  title: "Premium",
        icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z",
        desc: "Above-average pricing with enhanced specs or strong branding." },
      { colour: "purple", title: "Luxury",
        icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
        desc: "Top-tier pricing. Flagship specs or exclusive brand appeal." }
    ].each do |item| %>
      <%
        bg  = { "green"=>"bg-green-100",  "blue"=>"bg-blue-100",  "amber"=>"bg-amber-100",  "purple"=>"bg-purple-100"  }[item[:colour]]
        ic  = { "green"=>"text-green-600","blue"=>"text-blue-600","amber"=>"text-amber-600","purple"=>"text-purple-600" }[item[:colour]]
        hd  = { "green"=>"text-green-700","blue"=>"text-blue-700","amber"=>"text-amber-700","purple"=>"text-purple-700" }[item[:colour]]
      %>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center card-hover">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl mb-3 <%= bg %>">
          <svg class="w-6 h-6 <%= ic %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
          </svg>
        </div>
        <h3 class="font-bold text-sm mb-1 <%= hd %>"><%= item[:title] %></h3>
        <p class="text-gray-500 text-xs leading-relaxed"><%= item[:desc] %></p>
      </div>
    <% end %>
  </div>
</div>

<!-- ======================================================
     TECH PILL ROW
     ====================================================== -->
<div class="mt-8 flex flex-wrap justify-center gap-2">
  <% %w[Logistic\ Regression Random\ Forest XGBoost LightGBM TF-IDF\ (bigrams)
         SHAP\ Explainability SMOTE\ Oversampling Flipkart\ Dataset Amazon\ Dataset].each do |tag| %>
    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium
                 bg-gray-100 text-gray-600 border border-gray-200"><%= tag %></span>
  <% end %>
</div>
